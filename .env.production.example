# ============================================================
# VERCEL ENVIRONMENT VARIABLES
# Add ALL of these in: Vercel Dashboard → Project → Settings → Environment Variables
# ============================================================

# MongoDB Atlas connection string (required)
# Get this from: https://cloud.mongodb.com → Connect → Drivers
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/retaildb?retryWrites=true&w=majority"

# NextAuth (required)
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate-a-random-32-char-string-here"

# Email for EOD reports (required for cron emails)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-gmail@gmail.com"
EMAIL_PASS="your-gmail-app-password"

# Cron job security (recommended)
# Generate any random string — used to secure /api/cron/* endpoints
CRON_SECRET="generate-a-random-secret-here"

# Stripe (optional — for card payments)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLIC_KEY="pk_live_..."

# ============================================================
# DEPLOYMENT CHECKLIST
# ============================================================
# 1. Push code to GitHub
# 2. Import project in Vercel (vercel.com/new)
# 3. Add all env vars above in Vercel dashboard
# 4. Deploy — Vercel runs `prisma generate && next build` automatically
# 5. After deploy, go to Storage → connect MongoDB Atlas
# 6. Run seed: npx prisma db seed (from local machine with Atlas URL)
# 7. Cron jobs fire automatically: EOD at 9PM WAT, low-stock at 8AM WAT
# ============================================================
