// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  WHOLESALE_CUSTOMER
}

enum CustomerType {
  RETAIL
  WHOLESALE
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
}

enum SaleStatus {
  COMPLETED
  VOIDED
  HELD
}

model User {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String     @unique
  password      String
  role          Role
  branch        Branch?    @relation(fields: [branchId], references: [id])
  branchId      String?    @db.ObjectId
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  sales         Sale[]
  expenses      Expense[]
  auditLogs     AuditLog[]

  @@index([branchId])
}

model Branch {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  address       String
  phone         String
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  users         User[]
  products      Product[]
  sales         Sale[]
  customers     Customer[]
  expenses      Expense[]

  @@index([isActive])
}

model Product {
  id                String     @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  sku               String     @unique
  barcode           String?    @unique
  category          Category   @relation(fields: [categoryId], references: [id])
  categoryId        String     @db.ObjectId
  retailPrice       Float
  wholesalePrice    Float
  stockQty          Int
  lowStockThreshold Int        @default(10)
  supplier          Supplier   @relation(fields: [supplierId], references: [id])
  supplierId        String     @db.ObjectId
  branch            Branch     @relation(fields: [branchId], references: [id])
  branchId          String     @db.ObjectId
  imageUrl          String?
  unit              String     @default("pcs")
  minOrderQty       Int        @default(1)
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  saleItems        SaleItem[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([branchId])
  @@index([isActive])
}

model Category {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  name          String     @unique
  parent        Category?  @relation("CategoryToParent", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentId      String?    @db.ObjectId
  children      Category[] @relation("CategoryToParent")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  products      Product[]

  @@index([parentId])
}

model Supplier {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  contact       String
  email         String?
  phone         String
  address       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  products      Product[]

  @@index([email])
}

model Customer {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String?
  phone         String?
  type          CustomerType @default(RETAIL)
  creditLimit   Float?
  creditUsed    Float        @default(0)
  branch        Branch       @relation(fields: [branchId], references: [id])
  branchId      String       @db.ObjectId
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  sales         Sale[]

  @@index([branchId])
  @@index([type])
  @@index([email])
}

model Sale {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  customer        Customer   @relation(fields: [customerId], references: [id])
  customerId      String     @db.ObjectId
  cashier         User       @relation(fields: [cashierId], references: [id])
  cashierId       String     @db.ObjectId
  subtotal        Float
  tax             Float
  discount        Float      @default(0)
  total           Float
  paymentMethod   PaymentMethod
  status          SaleStatus @default(COMPLETED)
  notes           String?
  branch          Branch     @relation(fields: [branchId], references: [id])
  branchId        String     @db.ObjectId
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  items           SaleItem[]

  @@index([customerId])
  @@index([cashierId])
  @@index([branchId])
  @@index([createdAt])
  @@index([status])
}

model SaleItem {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  sale            Sale       @relation(fields: [saleId], references: [id])
  saleId          String     @db.ObjectId
  product         Product    @relation(fields: [productId], references: [id])
  productId       String     @db.ObjectId
  qty             Int
  unitPrice       Float
  discount        Float      @default(0)
  total           Float
  createdAt       DateTime   @default(now())

  @@index([saleId])
  @@index([productId])
}

model Expense {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  category        String
  amount          Float
  description     String
  date            DateTime
  user            User       @relation(fields: [userId], references: [id])
  userId          String     @db.ObjectId
  branch          Branch     @relation(fields: [branchId], references: [id])
  branchId        String     @db.ObjectId
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([userId])
  @@index([branchId])
  @@index([date])
}

model DiscountCode {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  code            String     @unique
  type            String     // PERCENTAGE or FIXED
  value           Float
  expiryDate      DateTime?
  usageLimit      Int?
  usageCount      Int        @default(0)
  isActive        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([isActive])
}

model AuditLog {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  user            User       @relation(fields: [userId], references: [id])
  userId          String     @db.ObjectId
  action          String
  entity          String
  entityId        String
  oldValue        String?
  newValue        String?
  timestamp       DateTime   @default(now())

  @@index([userId])
  @@index([entity])
  @@index([timestamp])
}

model Setting {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  key             String     @unique
  value           String
  description     String?
  updatedAt       DateTime   @updatedAt

}
