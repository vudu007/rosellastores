// Prisma Schema - MongoDB
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OWNER
  MANAGER
  CASHIER
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
  SPLIT
}

enum SaleStatus {
  COMPLETED
  VOIDED
  HELD
  RETURNED
  PARTIALLY_RETURNED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  COMPLETED
  REJECTED
}

enum PriceTagStatus {
  PENDING
  PRINTED
}

enum DeletionEntityType {
  CATEGORY
  PRODUCT
  SUPPLIER
}

enum DeletionStatus {
  SOFT_DELETED
  APPROVED
  PERMANENT_DELETED
  CANCELLED
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String    @unique
  password  String
  role      Role
  branchId  String?   @db.ObjectId
  branch    Branch?   @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tempExpiresAt DateTime?

  sales     Sale[]
  expenses  Expense[]
  auditLogs AuditLog[]
  sessions  UserSession[]
  revokedSessions UserSession[] @relation("RevokedBy")
  loginEvents LoginEvent[]
  deletionRequests DeletionRequest[] @relation("DeletionRequestedBy")
  deletionApprovals DeletionRequest[] @relation("DeletionApprovedBy")
  deletionExecutions DeletionRequest[] @relation("DeletionExecutedBy")
  returnRequests ReturnRequest[] @relation("ReturnRequestedBy")
  returnOwnerApprovals ReturnRequest[] @relation("ReturnOwnerApprovedBy")
  returnAdminApprovals ReturnRequest[] @relation("ReturnAdminApprovedBy")
  returnExecutions ReturnRequest[] @relation("ReturnExecutedBy")
  returnRejections ReturnRequest[] @relation("ReturnRejectedBy")

  @@index([branchId])
}

model Branch {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  address   String
  phone     String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users     User[]
  products  Product[]
  sales     Sale[]
  customers Customer[]
  expenses  Expense[]
  priceTags PriceTag[]
  returns   ReturnRequest[]

  @@index([isActive])
}

model Product {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  sku               String    @unique
  barcodes          String[]
  categoryId        String    @db.ObjectId
  category          Category  @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  costPrice         Float     @default(0)
  retailPrice       Float
  stockQty          Int
  lowStockThreshold Int       @default(10)
  supplierId        String    @db.ObjectId
  supplier          Supplier  @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branchId          String    @db.ObjectId
  branch            Branch    @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  imageUrl          String?
  unit              String    @default("pcs")
  minOrderQty       Int       @default(1)
  isActive          Boolean   @default(true)
  deletedAt         DateTime?
  deletedById       String?   @db.ObjectId
  isTaxable         Boolean   @default(true)
  taxInclusive      Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  saleItems SaleItem[]
  priceTags PriceTag[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([branchId])
  @@index([isActive])
}

model PriceTag {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  productId String         @db.ObjectId
  product   Product        @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branchId  String         @db.ObjectId
  branch    Branch         @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  oldPrice  Float
  newPrice  Float
  status    PriceTagStatus @default(PENDING)
  printedAt DateTime?
  createdAt DateTime       @default(now())

  @@index([productId])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
}

model Category {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String     @unique
  parentId  String?    @db.ObjectId
  parent    Category?  @relation("CategoryToParent", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  Category[] @relation("CategoryToParent")
  isActive  Boolean    @default(true)
  deletedAt DateTime?
  deletedById String?  @db.ObjectId
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  products Product[]

  @@index([parentId])
  @@index([isActive])
}

model Supplier {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  contact   String
  email     String?
  phone     String
  address   String?
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  deletedById String? @db.ObjectId
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products Product[]

  @@index([email])
  @@index([isActive])
}

model UserSession {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @db.ObjectId
  user       User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ip         String?
  userAgent  String?
  device     String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime?
  revokedAt  DateTime?
  revokedById String?  @db.ObjectId
  revokedBy  User?     @relation("RevokedBy", fields: [revokedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  revokeReason String?

  @@index([userId])
  @@index([createdAt])
  @@index([lastSeenAt])
  @@index([revokedAt])
}

model LoginEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  email     String
  success   Boolean
  error     String?
  ip        String?
  userAgent String?
  device    String?
  sessionId String?  @db.ObjectId
  timestamp DateTime @default(now())

  @@index([email])
  @@index([timestamp])
  @@index([success])
}

model DeletionRequest {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  entityType  DeletionEntityType
  entityId    String            @db.ObjectId
  reason      String
  requestedAt DateTime          @default(now())
  earliestPermanentAt DateTime
  status      DeletionStatus    @default(SOFT_DELETED)
  requestedById String          @db.ObjectId
  requestedBy User             @relation("DeletionRequestedBy", fields: [requestedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedById String?          @db.ObjectId
  approvedBy User?             @relation("DeletionApprovedBy", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedAt DateTime?
  executedById String?          @db.ObjectId
  executedBy User?             @relation("DeletionExecutedBy", fields: [executedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  executedAt DateTime?

  @@index([entityType])
  @@index([entityId])
  @@index([status])
  @@index([requestedAt])
  @@index([earliestPermanentAt])
}

model ReturnRequest {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  saleId    String       @unique @db.ObjectId
  sale      Sale         @relation(fields: [saleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branchId  String       @db.ObjectId
  branch    Branch       @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reason    String
  items     Json?
  status    ReturnStatus @default(REQUESTED)
  requestedAt DateTime   @default(now())

  requestedById String   @db.ObjectId
  requestedBy   User     @relation("ReturnRequestedBy", fields: [requestedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  ownerApprovedById String? @db.ObjectId
  ownerApprovedBy   User?   @relation("ReturnOwnerApprovedBy", fields: [ownerApprovedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ownerApprovedAt   DateTime?

  adminApprovedById String? @db.ObjectId
  adminApprovedBy   User?   @relation("ReturnAdminApprovedBy", fields: [adminApprovedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  adminApprovedAt   DateTime?

  executedById String? @db.ObjectId
  executedBy   User?   @relation("ReturnExecutedBy", fields: [executedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  executedAt   DateTime?

  rejectedById String? @db.ObjectId
  rejectedBy   User?   @relation("ReturnRejectedBy", fields: [rejectedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rejectedAt   DateTime?

  @@index([branchId])
  @@index([status])
  @@index([requestedAt])
}

model Customer {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String?
  phone       String?
  branchId    String       @db.ObjectId
  branch      Branch       @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  sales Sale[]

  @@index([branchId])
  @@index([email])
}

model Sale {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  clientSaleId  String?       @unique
  customerId    String        @db.ObjectId
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cashierId     String        @db.ObjectId
  cashier       User          @relation(fields: [cashierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subtotal      Float
  tax           Float
  discount      Float         @default(0)
  total         Float
  paymentMethod PaymentMethod
  status        SaleStatus    @default(COMPLETED)
  notes         String?
  branchId      String        @db.ObjectId
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items SaleItem[]
  returnRequest ReturnRequest?

  @@index([customerId])
  @@index([cashierId])
  @@index([branchId])
  @@index([createdAt])
  @@index([status])
}

model SaleItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  saleId    String   @db.ObjectId
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  qty       Int
  unitPrice Float
  discount  Float    @default(0)
  total     Float
  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([productId])
}

model Expense {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  category    String
  amount      Float
  description String
  date        DateTime
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branchId    String   @db.ObjectId
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([branchId])
  @@index([date])
}

model DiscountCode {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  code       String    @unique
  type       String
  value      Float
  expiryDate DateTime?
  usageLimit Int?
  usageCount Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([isActive])
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  action    String
  entity    String
  entityId  String
  oldValue  String?
  newValue  String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([timestamp])
}

model Setting {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

}
